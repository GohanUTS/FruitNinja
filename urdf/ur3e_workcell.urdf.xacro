<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="ur3e_workcell">
  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>

  <!-- World frame -->
  <link name="world"/>

  <!-- Table mount point fixed in world -->
  <link name="table_mount"/>
  <joint name="world_to_table_mount" type="fixed">
    <parent link="world"/>
    <child link="table_mount"/>
    <origin xyz="0.365 0.355 1.0" rpy="0 0 0"/>
  </joint>

  <!-- UR3e mounted on table -->
  <xacro:ur_robot
    name="ur3e"
    tf_prefix=""
    parent="table_mount"
    joint_limits_parameters_file="$(find ur_description)/config/ur3e/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur3e/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur3e/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur3e/visual_parameters.yaml">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:ur_robot>

</robot>